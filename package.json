{
  "name": "kitemcp-portfolio-intelligence",
  "version": "1.1.0",
  "description": "AI-powered portfolio intelligence for Indian equity markets (NSE/BSE)",
  "main": "run_daily.js",
  "scripts": {
    "start": "node archive_reports.js && node run_daily.js",
    "report": "node create_daily_report.js",
    "report:individual": "node create_individual_reports.js",
    "report:all": "node create_daily_report.js && node create_individual_reports.js",
    "report:readable": "node create_readable_reports.js",
    "export": "node create_portfolio_export.js",
    "archive": "node archive_reports.js",
    "archive:preview": "node archive_reports.js --dry-run",
    "scan": "node scan_opportunities.js",
    "login": "node kite_login.js",
    "login:status": "node kite_login.js status",
    "login:open": "node kite_login.js open",
    "all": "node scan_opportunities.js && node create_daily_report.js && node create_portfolio_export.js",
    "export:weekly": "node create_weekly_export.js",
    "deep-discount": "node create_deep_discount_report.js",
    "check": "node check_gates.js"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "exceljs": "^4.4.0"
  }
}
